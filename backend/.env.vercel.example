# Vercel runtime
NODE_ENV=production
PORT=3000

# Database mode: mysql (legacy) or postgres (Supabase)
DB_CLIENT=postgres

# Public URL used when backend generates absolute URLs (QR code, links)
PUBLIC_BASE_URL=https://your-project.vercel.app

# Keep CORS open by default (existing behavior). Optional hardening:
# CORS_ORIGIN=https://your-frontend-domain.vercel.app

# Supabase transaction pooler URI (recommended for Vercel serverless)
DATABASE_URL=postgresql://postgres.<project-ref>:[password]@aws-0-<region>.pooler.supabase.com:6543/postgres
DB_SSL=true

# Supabase Storage (required for uploads/qrcode on Vercel)
STORAGE_MODE=supabase
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>
SUPABASE_BUCKET_BORROWING=borrowing
SUPABASE_BUCKET_REPAIRS=repairs
SUPABASE_BUCKET_REPORTS=reports
SUPABASE_BUCKET_QRCODES=qrcodes
SUPABASE_BUCKET_UPLOADS=uploads

# Legacy MySQL fallback values (used when DB_CLIENT=mysql)
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=password123
# DB_NAME=my_database
